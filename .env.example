# ─────────────────────────────────────────────────────────────────────────────
#  AgentLaunch — environment variables
#  Copy to .env and fill in your values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the *browser* uses to reach the API.
# For local Docker Compose this should be http://localhost:4000.
# For a remote deployment, use your public API domain.
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── API / Backend ─────────────────────────────────────────────────────────────
# PostgreSQL runs inside the same container on 127.0.0.1.
# Override only if you point to an external database.
DATABASE_URL=postgres://agentlaunch:agentlaunch@127.0.0.1:5432/agentlaunch

# BNB Chain RPC endpoint (default: public BSC testnet)
BNB_RPC_URL=https://bsc-testnet-dataseed.bnbchain.org

# Token-gate: minimum token balance (in wei) required to call agent endpoints
# Default 1e18 = 1 full token
TOKEN_GATE_THRESHOLD=1000000000000000000

# Wallet signature TTL in seconds (default: 300 = 5 minutes)
SIGNATURE_TTL_SECONDS=300

# ── CreateOS — AI container orchestration ─────────────────────────────────────
# Required to deploy AI agent Docker images.
CREATEOS_API_URL=https://api-createos.nodeops.network/v1
CREATEOS_API_KEY=your_createos_api_key_here

# Resource limits per agent container
CREATEOS_CPU=200
CREATEOS_MEMORY=512
CREATEOS_REPLICAS=1

# ── LLM API keys (forwarded to agent containers) ──────────────────────────────
# At least one is needed if your agents use cloud AI providers.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
