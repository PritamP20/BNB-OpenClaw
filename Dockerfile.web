# syntax=docker/dockerfile:1
# ─── Stage 1: Build Web (Next.js standalone) ─────────────────────────────────
FROM node:20-alpine AS builder
WORKDIR /repo

COPY package.json package-lock.json turbo.json ./
COPY apps/web/package.json                      ./apps/web/
COPY packages/ui/package.json                   ./packages/ui/
COPY packages/typescript-config/package.json    ./packages/typescript-config/
COPY packages/eslint-config/package.json        ./packages/eslint-config/
RUN npm ci --ignore-scripts

# NEXT_PUBLIC_* are baked into the JS bundle at build time.
# On NodeOps all services share localhost, so the browser-side API calls
# go to the nginx proxy at /api which forwards to 127.0.0.1:4000.
ARG NEXT_PUBLIC_API_URL=http://localhost:4000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    NEXT_TELEMETRY_DISABLED=1

COPY apps/web/                   ./apps/web/
COPY packages/ui/                ./packages/ui/
COPY packages/typescript-config/ ./packages/typescript-config/
COPY packages/eslint-config/     ./packages/eslint-config/

WORKDIR /repo/apps/web
RUN npm run build

# ─── Stage 2: Runtime (non-root, user 65535 — required by NodeOps) ───────────
FROM node:20-alpine
WORKDIR /app

COPY --from=builder /repo/apps/web/.next/standalone/apps/web/ ./
COPY --from=builder /repo/apps/web/.next/standalone/node_modules ./node_modules
COPY --from=builder /repo/apps/web/.next/static ./.next/static
COPY --from=builder /repo/apps/web/public        ./public

# NodeOps runs containers as user 65535 (non-root)
RUN chown -R 65535:65535 /app
USER 65535

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    HOSTNAME=0.0.0.0 \
    PORT=3000

EXPOSE 3000
CMD ["node", "--max-old-space-size=512", "server.js"]
