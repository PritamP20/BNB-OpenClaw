# ── Server ─────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/agentlaunch
# ── BNB Chain RPC ───────────────────────────────────
BNB_RPC_URL=https://bsc-testnet-dataseed.bnbchain.org

# ── Token Gating ────────────────────────────────────
# Minimum tokens to hold (in wei, 18 decimals) — default 1 token
TOKEN_GATE_THRESHOLD=1000000000000000000
# Signed message window in seconds (prevent replay attacks)
SIGNATURE_TTL_SECONDS=300

# ── CreateOS API ────────────────────────────────────
CREATEOS_API_URL=https://api.createos.xyz
CREATEOS_API_KEY=your_createos_api_key_here

# Default resource limits per agent container
CREATEOS_CPU=200       # millicores (200–500)
CREATEOS_MEMORY=512    # MB (500–1024)
CREATEOS_REPLICAS=1
